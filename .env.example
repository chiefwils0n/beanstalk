# Your real, live books. `npm run dev` overrides this to point at sandbox.db
# so development never touches production data — see README.
DATABASE_URL="file:./beanstalk.db"

# Optional single-password login. Leave blank to disable auth (e.g. when the
# app only runs on localhost or behind a VPN). Set it to require a password to
# access the app. Use a strong, unique value.
AUTH_PASSWORD=""

# Google Workspace (Drive) integration — create OAuth credentials at
# https://console.cloud.google.com/apis/credentials and enable the Drive API.
# Authorized redirect URI: http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APP_URL="http://localhost:3000"

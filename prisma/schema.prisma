generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id              String   @id @default(cuid())
  name            String
  legalName       String?
  taxId           String?
  fiscalYearStart Int      @default(1) // month 1-12
  driveFolderId   String?
  createdAt       DateTime @default(now())

  accounts     Account[]
  entries      JournalEntry[]
  tags         Tag[]
  classes      Class[]
  contacts        Contact[]
  contactTypes    ContactType[]
  invoices        Invoice[]
  recurring       RecurringTransaction[]
  documents       Document[]
  loans           Loan[]
  reconciliations Reconciliation[]
  auditEvents     AuditEvent[]
}

// An immutable record of a change to a journal entry (created / updated /
// voided / deleted). `entryId` is a plain reference, not a foreign key, so the
// audit row survives after the entry is deleted.
model AuditEvent {
  id         String   @id @default(cuid())
  businessId String
  entryId    String?
  action     String // CREATED | UPDATED | VOIDED | DELETED
  memo       String
  amount     Int      @default(0) // entry total (debits), cents
  detail     String? // JSON snapshot of the entry at the time
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([entryId])
}

// User-defined contact categories (Customer, Vendor, Tenant, Lead, …).
model ContactType {
  id         String @id @default(cuid())
  businessId String
  name       String
  color      String @default("#0ea5e9")

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contacts Contact[]

  @@unique([businessId, name])
}

model Loan {
  id                 String   @id @default(cuid())
  businessId         String
  name               String
  lenderId           String?
  principal          Int // original principal, cents
  annualRate         Float // percent, e.g. 6.5
  termMonths         Int
  firstPaymentDate   DateTime
  payment            Int // standard monthly payment, cents
  liabilityAccountId String
  interestAccountId  String
  paymentAccountId   String
  notes              String?
  status             String   @default("ACTIVE") // ACTIVE | CLOSED
  closedAt           DateTime?
  closureNote        String?
  replacesId         String? // the loan this one supersedes (e.g. a balloon refinance)
  createdAt          DateTime @default(now())

  business         Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lender           Contact?      @relation(fields: [lenderId], references: [id], onDelete: SetNull)
  liabilityAccount Account       @relation("LoanLiabilityAccount", fields: [liabilityAccountId], references: [id])
  interestAccount  Account       @relation("LoanInterestAccount", fields: [interestAccountId], references: [id])
  paymentAccount   Account       @relation("LoanPaymentAccount", fields: [paymentAccountId], references: [id])
  payments         LoanPayment[]
  replaces         Loan?         @relation("LoanSuccession", fields: [replacesId], references: [id], onDelete: SetNull)
  replacedBy       Loan[]        @relation("LoanSuccession")
}

model LoanPayment {
  id        String   @id @default(cuid())
  loanId    String
  date      DateTime
  interest  Int      @default(0) // cents
  principal Int      @default(0) // cents, includes extra principal
  extra     Int      @default(0) // cents, portion of principal beyond the scheduled amount
  entryId   String?  @unique
  createdAt DateTime @default(now())

  loan  Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  entry JournalEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
}

// Line-level reporting dimension (department, location, product line, …),
// like QuickBooks classes. Deleting a class leaves its lines unclassified.
model Class {
  id         String @id @default(cuid())
  businessId String
  name       String

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines          JournalLine[]
  recurringLines RecurringLine[]
  invoiceItems   InvoiceItem[]

  @@unique([businessId, name])
}

// type: ASSET | LIABILITY | EQUITY | INCOME | EXPENSE
model Account {
  id          String  @id @default(cuid())
  businessId  String
  code        String?
  name        String
  type        String
  description String?
  taxLine     String?
  isArchived  Boolean @default(false)
  parentId    String?

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent   Account?      @relation("AccountChildren", fields: [parentId], references: [id])
  children Account[]     @relation("AccountChildren")
  lines    JournalLine[]
  recurringLines RecurringLine[]
  invoiceItems   InvoiceItem[]
  loansAsLiability Loan[] @relation("LoanLiabilityAccount")
  loansAsInterest  Loan[] @relation("LoanInterestAccount")
  loansAsPayment   Loan[] @relation("LoanPaymentAccount")
  reconciliations  Reconciliation[]

  @@index([businessId, type])
}

// status: POSTED | VOID
model JournalEntry {
  id          String   @id @default(cuid())
  businessId  String
  date        DateTime
  memo        String
  reference   String?
  status      String   @default("POSTED")
  invoiceId   String?
  recurringId String?
  createdAt   DateTime @default(now())

  business    Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice     Invoice?              @relation(fields: [invoiceId], references: [id])
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id])
  lines       JournalLine[]
  tags        EntryTag[]
  documents   Document[]
  loanPayment LoanPayment?

  @@index([businessId, date])
}

model JournalLine {
  id               String  @id @default(cuid())
  entryId          String
  accountId        String
  classId          String?
  contactId        String?
  description      String?
  debit            Int     @default(0) // cents
  credit           Int     @default(0) // cents
  cleared          String  @default("NONE") // NONE | CLEARED | RECONCILED
  reconciliationId String?

  entry          JournalEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account        Account         @relation(fields: [accountId], references: [id])
  class          Class?          @relation(fields: [classId], references: [id], onDelete: SetNull)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  reconciliation Reconciliation? @relation(fields: [reconciliationId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([classId])
  @@index([contactId])
}

// A finished statement reconciliation for one bank/credit-card account.
model Reconciliation {
  id            String   @id @default(cuid())
  businessId    String
  accountId     String
  statementDate DateTime
  endingBalance Int // cents, signed by the account's normal balance
  createdAt     DateTime @default(now())

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  account  Account       @relation(fields: [accountId], references: [id])
  lines    JournalLine[]

  @@index([businessId, accountId])
}

model Tag {
  id         String @id @default(cuid())
  businessId String
  name       String
  color      String @default("#10b981")

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  entries  EntryTag[]

  @@unique([businessId, name])
}

model EntryTag {
  entryId String
  tagId   String

  entry JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag   Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
}

// `name` is the display name (company or person); the detail fields are
// optional. Contacts have a user-defined type (Customer, Vendor, Tenant, …),
// can nest under a parent contact (e.g. tenants under a household), and can be
// linked to individual journal lines for per-name reporting.
model Contact {
  id         String  @id @default(cuid())
  businessId String
  typeId     String?
  parentId   String?
  name       String
  firstName  String?
  lastName   String?
  company    String?
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  zip        String?
  notes      String?

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type           ContactType?    @relation(fields: [typeId], references: [id], onDelete: SetNull)
  parent         Contact?        @relation("ContactChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       Contact[]       @relation("ContactChildren")
  invoices       Invoice[]
  lines          JournalLine[]
  recurringLines RecurringLine[]
  loans          Loan[]

  @@index([businessId, typeId])
}

// status: DRAFT | SENT | PAID | VOID
model Invoice {
  id         String   @id @default(cuid())
  businessId String
  customerId String
  number     String
  issueDate  DateTime
  dueDate    DateTime
  status     String   @default("DRAFT")
  notes      String?
  total      Int      @default(0) // cents
  createdAt  DateTime @default(now())

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Contact        @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]
  entries  JournalEntry[]
  documents Document[]

  @@unique([businessId, number])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  accountId   String // income account
  classId     String?
  description String
  quantity    Float   @default(1)
  unitPrice   Int     @default(0) // cents
  amount      Int     @default(0) // cents

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)
}

// frequency: DAILY | WEEKLY | MONTHLY | YEARLY
model RecurringTransaction {
  id         String    @id @default(cuid())
  businessId String
  name       String
  memo       String?
  frequency  String
  interval   Int       @default(1)
  nextRun    DateTime
  endDate    DateTime?
  lastRun    DateTime?
  autoPost   Boolean   @default(true)
  isActive   Boolean   @default(true)

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines    RecurringLine[]
  entries  JournalEntry[]
}

model RecurringLine {
  id          String  @id @default(cuid())
  recurringId String
  accountId   String
  classId     String?
  contactId   String?
  description String?
  debit       Int     @default(0)
  credit      Int     @default(0)

  recurring RecurringTransaction @relation(fields: [recurringId], references: [id], onDelete: Cascade)
  account   Account              @relation(fields: [accountId], references: [id])
  class     Class?               @relation(fields: [classId], references: [id], onDelete: SetNull)
  contact   Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

// category: RECEIPT | CONTRACT | OTHER ; storage: drive | local
model Document {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  mimeType    String?
  category    String   @default("OTHER")
  storage     String   @default("drive")
  driveFileId String? // set when storage = drive
  localKey    String? // on-disk filename under the uploads dir, when storage = local
  webViewLink String?
  entryId     String?
  invoiceId   String?
  createdAt   DateTime @default(now())

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  entry    JournalEntry? @relation(fields: [entryId], references: [id])
  invoice  Invoice?      @relation(fields: [invoiceId], references: [id])
}

model GoogleAuth {
  id           String  @id @default("default")
  accessToken  String
  refreshToken String?
  expiryDate   BigInt?
  scope        String?
  email        String?
}
